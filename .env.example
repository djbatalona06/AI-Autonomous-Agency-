# =============================================================================
# Yawn — example environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values. NEVER commit a real `.env` (it is
# gitignored). Yawn runs without the AI keys (features fall back to mocks), but
# SESSION_SECRET MUST be set to a strong random value in production.
# =============================================================================

# Node environment: "development" | "production"
NODE_ENV=development

# Server port (Express + tRPC). Default: 3001
PORT=3001

# ── Sessions / auth ──────────────────────────────────────────────────────────
# Signs the session cookie (HMAC). Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# In production the app REFUSES TO START if this is unset or left at the default.
SESSION_SECRET=replace-with-a-long-random-secret
# Session lifetime in days (default 7).
SESSION_TTL_DAYS=7

# ── Rate limiting (in-memory, per serverless instance) ───────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_AUTH_MAX=20        # max auth requests per window per IP
RATE_LIMIT_GLOBAL_MAX=300     # max /trpc requests per window per IP

# ── LLM (web-crawler intelligence + chat agent) ──────────────────────────────
# Provider auto-selected: Anthropic if ANTHROPIC_API_KEY set, else OpenAI, else mock.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=claude-sonnet-4-6

# ── Web scraping (optional) ──────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ── Supabase (target database — see supabase/README.md) ──────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # SECRET — server only, bypasses RLS. Never expose to the browser.
SUPABASE_DB_URL=             # Postgres connection string used by the backend

# ── Backups (optional) ───────────────────────────────────────────────────────
# When set, store backups are encrypted with AES-256-GCM (scripts/backup-store.mjs).
BACKUP_ENCRYPTION_KEY=
# Overrides for backup tooling (defaults derive from the store location):
# STORE_PATH=
# BACKUP_DIR=
