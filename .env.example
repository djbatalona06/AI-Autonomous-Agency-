# ────────────────────────────────────────────────────────────────────────────
# Yawn runs fully WITHOUT any of these — AI features fall back to deterministic
# mocks so the app is usable offline. Set keys to enable real providers.
# ────────────────────────────────────────────────────────────────────────────

# Server port (Express + tRPC). Default: 3001
PORT=3001

# Signs the legacy session cookie (unused once Supabase auth is live).
SESSION_SECRET=yawn-dev-secret-change-me

# ── Supabase (auth + data) ──
# Project: odibvergwcllhsbzbgwa ("AI Automation Agency").
# The anon key is PUBLIC by design (safe in client code); the server verifies
# user JWTs with it via supabase.auth.getUser — NO service_role key is needed.
# Fetch it: npx supabase projects api-keys --project-ref odibvergwcllhsbzbgwa
VITE_SUPABASE_URL=https://odibvergwcllhsbzbgwa.supabase.co
VITE_SUPABASE_ANON_KEY=
# The server reads these (same values); Vite exposes VITE_* to the client only.
SUPABASE_URL=https://odibvergwcllhsbzbgwa.supabase.co
SUPABASE_ANON_KEY=

# ── LLM (web-crawler intelligence + chat agent) ──
# Provider is auto-selected: Anthropic if ANTHROPIC_API_KEY is set, else OpenAI
# if OPENAI_API_KEY is set, else a built-in mock.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=claude-sonnet-4-6        # Anthropic default
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Image generation ──
# If OPENAI_API_KEY is set, real images are generated. Otherwise a branded
# brutalist SVG placeholder is produced from the prompt.

# ── Web scraping ──
# Live scraping uses native fetch. Optionally route through Firecrawl:
# FIRECRAWL_API_KEY=
# Outbound scrape URLs are checked against an SSRF guard (server/_core/scrape.ts)
# that blocks loopback / private / link-local / cloud-metadata targets.

# ── Security edge (server/_core/security.ts) ──
# CORS is default-deny. List production browser origins that may call the API,
# comma-separated (localhost dev origins are allowed automatically in dev):
# CORS_ALLOWED_ORIGINS=https://yawn.example,https://app.yawn.example
# Per-IP rate-limit tuning (defaults shown). Window is shared by both limiters.
# RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
# RATE_LIMIT_AUTH_MAX=50             # requests/window to /api/auth
# RATE_LIMIT_API_MAX=300             # requests/window to /trpc
